# ─── Metis MVP — Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# Required: Google Gemini API key (used by /api/chat and /api/doc-synthesis)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: API secret for protecting internal endpoints.
# When set, all POST requests to /api/chat and /api/doc-synthesis must include:
#   Authorization: Bearer <METIS_API_SECRET>
# Leave empty (or unset) to disable auth check in local development.
METIS_API_SECRET=
